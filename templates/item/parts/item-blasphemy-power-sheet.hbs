<form class='{{cssClass}} agenda-background' autocomplete='off'>
  <header class='sheet-header agenda-header'>
    <img
      class='profile-img'
      src='{{img}}'
      data-edit='img'
      title='{{name}}'
    />
    <div class='header-fields'>
      <h1 class='charname agenda-ability-name'><input
          name='name'
          type='text'
          value='{{name}}'
          placeholder='Name'
          style='color: white; background-color: transparent; border: none; border-bottom: 2px solid #555;'
        /></h1>
    </div>
  </header>

  <nav class='sheet-tabs tabs agenda-tabs' data-group='primary'>
    <a class='item' data-tab='power'>Power</a>
  </nav>

  <section class='sheet-body agenda-body'>
    <div class='tab agenda-text-color' data-group='primary' data-tab='power'>
      <div class='form-group' style='display:flex; flex-direction:column; gap:6px;'>
        <label for='powerName' style='color: white;'>Power Name</label>
        <input
          type='text'
          name='system.powerName'
          value='{{system.powerName}}'
          data-dtype='String'
          style='width: 100%; color: white; background-color: #333; border: 1px solid #555; border-radius: 4px; padding: 8px; box-sizing: border-box;'
        />
      </div>

      <div class='form-group' style='display:flex; flex-direction:column; gap:6px;'>
        <label for='powerDescription' style='color: white;'>Power Description</label>
        <textarea
          name='system.powerDescription'
          data-dtype='String'
          rows='12'
          style='width: 100%; color: white; background-color: #333; border: 1px solid #555; border-radius: 4px; padding: 8px; box-sizing: border-box; resize: vertical;'
        >{{system.powerDescription}}</textarea>
      </div>

      <div class='form-group' style='display:flex; flex-direction:column; gap:6px; margin-top: 16px;'>
        <label for='ampDescription' style='color: #cc33ff; font-weight: bold;'>
          <i class='fas fa-bolt' style='margin-right: 4px;'></i>Sin Amp Description
        </label>
        <textarea
          name='system.ampDescription'
          data-dtype='String'
          rows='12'
          placeholder='Describe the effect when this power is Sin Amped…'
          style='width: 100%; color: #dda0dd; background-color: #1a0a1a; border: 1px solid #660066; border-radius: 4px; padding: 8px; box-sizing: border-box; resize: vertical;'
        >{{system.ampDescription}}</textarea>
      </div>
    </div>
  </section>
</form>
