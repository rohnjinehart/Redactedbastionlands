<form class='{{cssClass}} item-kit' autocomplete='off'>
  <header class='sheet-header'>
    <img class='profile-img' src='{{item.img}}' data-edit='img' title='{{item.name}}'/>
    <div class='header-fields'>
      <h1 class='charname'><input name='name' type='text' value='{{item.name}}' placeholder='Name'/></h1>
      <div class='grid grid-2col'>
        <div class='resource'>
          <label class='resource-label'>Armor Value</label>
          <input type='number' name='system.armor' value='{{system.armor}}' min='0' data-dtype='Number'/>
        </div>
        <div class='resource'>
          <label class='resource-label'>Type</label>
          <span style='color:#aaa;font-size:0.9em;padding-top:6px;display:block;'>Coat</span>
        </div>
      </div>
    </div>
  </header>

  <nav class='sheet-tabs tabs' data-group='primary'>
    <a class='item' data-tab='description'>Description</a>
  </nav>

  <section class='sheet-body'>
    <div class='tab' data-group='primary' data-tab='description'>
      {{editor enrichedDescription target='system.description' engine='prosemirror' button=true editable=editable}}
    </div>
  </section>
</form>
