  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  border-left: 1px solid #333;
  padding-left: 14px;
}

.mook-heading {
  margin: 0 0 4px 0;
  font-size: 0.8em;
}

.mook-inputs {
  margin-bottom: 4px;
}

.mook-progress {
  width: 100%;
  margin-bottom: 0;
}

.mook-armor-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
}

.mook-armor-input {
  width: 60px;
  padding: 3px 6px;
  font-size: 1.1em;
  font-weight: bold;
  text-align: center;
  background: #262626;
  border: 1px solid #444;
