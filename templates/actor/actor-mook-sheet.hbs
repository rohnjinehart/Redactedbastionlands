<form class="{{cssClass}} mook flexcol mob-psycho-theme no-border" autocomplete="off">

  {{!-- Header --}}
  <header class="sheet-header mob-psycho-header mook-header">
    <img class="profile-img mob-psycho-img mook-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <div class="header-fields mob-psycho-header-fields">
      <h1 class="charname mob-psycho-charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Mook Name"/>
      </h1>
      <span class="mook-type-label">Mook</span>
    </div>
  </header>

  {{!-- Body --}}
  <section class="sheet-body mob-psycho-body mook-body">
    <div class="mook-layout">

      {{!-- LEFT: Stats + Combat --}}
      <div class="mook-stats-col">

        {{!-- Resolve --}}
        <h3 class="mob-psycho-heading mook-heading">Resolve</h3>
        <div class="virtue-inputs mook-inputs">
          <input type="number" name="system.resolve.value" value="{{system.resolve.value}}" data-dtype="Number" min="0"/>
          <span>/</span>
          <input type="number" name="system.resolve.max" value="{{system.resolve.max}}" data-dtype="Number" min="0"/>
        </div>
        <progress class="virtue-progress guard-progress mook-progress"
                  value="{{system.resolve.value}}"
                  max="{{#if (gt system.resolve.max 0)}}{{system.resolve.max}}{{else}}1{{/if}}"></progress>

        {{!-- Resistance --}}
        <h3 class="mob-psycho-heading mook-heading" style="margin-top:10px;">Resistance</h3>
        <div class="mook-armor-row">
          <input type="number" name="system.armor" value="{{system.armor}}" data-dtype="Number" min="0" class="mook-armor-input"/>
        </div>

        {{!-- Burnout --}}
        <div class="mook-burnout-row">
          <input type="checkbox" name="system.burnout" id="mook-burnout" {{#if system.burnout}}checked{{/if}}/>
          <label for="mook-burnout" class="mook-burnout-label">Burnout</label>
        </div>

        {{!-- Combat --}}
        <h3 class="mob-psycho-heading mook-heading" style="margin-top:12px;">Combat</h3>
        <button type="button" class="rb-attack-btn mob-psycho-button rb-combat-btn">⚔ Attack</button>
        <button type="button" class="rb-take-damage-btn mob-psycho-button rb-combat-btn">🛡 Take Damage</button>
        <button type="button" class="rb-virtue-loss-btn mob-psycho-button rb-combat-btn">💀 Vital Loss</button>

      </div>

      {{!-- RIGHT: Weapons --}}
      <div class="mook-weapons-col">
        <h3 class="mob-psycho-heading mook-heading">Weapons</h3>

        <div class="mook-weapons-list">
          {{#each system.weapons}}
          <div class="mook-weapon-row" data-index="{{@index}}">
            <input type="text"   name="system.weapons.{{@index}}.name"   value="{{this.name}}"   placeholder="Weapon…" class="mook-weapon-name"/>
            <input type="text"   name="system.weapons.{{@index}}.damage" value="{{this.damage}}" placeholder="d6"       class="mook-weapon-dmg"/>
            <button type="button" class="opp-weapon-remove-btn mook-remove-btn" data-index="{{@index}}" title="Remove">
              <i class="fas fa-times"></i>
            </button>
          </div>
          {{/each}}
        </div>

        <button type="button" class="opp-weapon-add-btn mob-psycho-button mook-add-btn">
          <i class="fas fa-plus"></i> Add Weapon
        </button>
      </div>

    </div>
  </section>
</form>

<style>
