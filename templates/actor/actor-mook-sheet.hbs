}

.mook-body {
  padding: 10px;
  overflow-y: auto;
}

.mook-layout {
  display: flex;
  gap: 16px;
  height: 100%;
}

.mook-stats-col {
  flex: 0 0 160px;
  display: flex;
  flex-direction: column;
}

