    /* ==================== "OTHER" TYPE — HIDDEN SECTIONS ==================== */
    .opponent-theme.other .opp-trauma-card,
    .opponent-theme.other .opponent-domain-drop,
    .opponent-theme.other .opp-palace-card,
    .opponent-theme.other .opp-host-card {
        display: none;
    }

    .opponent-theme.other .opp-tend-palace-row,
    .opponent-theme.other .opp-host-appear-row {
        grid-template-columns: 1fr;
    }

    /* ==================== BASE (Dark Paper Theme) ==================== */
    .opponent-theme {
        background-image: url("systems/bastionlands/assets/backgrounds/paper1.jpg");
        background-color: var(--opp-bg);
        background-blend-mode: multiply;
        background-size: cover;
        color: var(--opp-text);
        font-family: 'Segoe UI', Tahoma, sans-serif;
        padding: 10px;
        gap: 10px;
    }

    /* ==================== HEADER ==================== */
    .opponent-header {
        background-image: url("systems/bastionlands/assets/backgrounds/paper2.jpg");
        background-color: var(--opp-bg-dark);
        background-blend-mode: multiply;
        background-size: cover;
        border: 2px solid var(--opp-accent-dim);
        border-radius: 8px;
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: none !important;
        flex-grow: 0 !important;
        flex-shrink: 0 !important;
    }

    /* Top Row: Portrait + Name + Actions */
    .header-top {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .portrait-frame {
        position: relative;
        flex-shrink: 0;
    }

    .profile-img {
        width: 70px;
        height: 70px;
        border: 2px solid var(--opp-accent);
        border-radius: 6px;
        object-fit: cover;
        box-shadow: 0 0 10px var(--opp-accent-glow);
        background-color: var(--opp-bg);
        display: block;
    }

    .category-badge {
        position: absolute;
        bottom: -6px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 3px;
        background: linear-gradient(180deg, #8b2020 0%, #5c0000 100%);
        border: 2px solid #ff6666;
        border-radius: 10px;
        padding: 1px 6px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.5);
    }

    .cat-label {
        font-size: 8px;
        font-weight: bold;
        color: #ffcccc;
        letter-spacing: 1px;
    }

    .opponent-theme .cat-input {
        width: 22px;
        padding: 0;
        text-align: center;
        font-weight: bold;
        font-size: 14px !important;
        color: #fff !important;
        background: transparent !important;
        border: none !important;
    }

    .name-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
        min-width: 0;
    }

    .opponent-theme .name-input {
        font-family: 'Pirata One', serif;
        font-size: 22px;
        padding: 2px 8px;
        background: rgba(20, 10, 30, 0.7);
        border: none;
        border-bottom: 2px solid var(--opp-accent);
        border-radius: 0;
        color: var(--opp-text) !important;
        width: 100%;
    }

    .opponent-theme .name-input::placeholder {
        color: var(--opp-accent-hover);
    }

    .type-line {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .opponent-theme .type-select {
        padding: 2px 8px;
        background: rgba(var(--opp-dim-rgb), 0.4);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 3px;
        color: var(--opp-text-mid);
        font-size: 12px;
        font-style: italic;
    }

    .opponent-theme .type-select option {
        background: var(--opp-bg);
        color: var(--opp-text);
    }

    .type-divider {
        color: var(--opp-accent-dim);
        font-size: 14px;
    }

    .opponent-theme .subtype-input {
        flex: 1;
        padding: 2px 8px;
        background: rgba(var(--opp-dim-rgb), 0.4);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 3px;
        color: var(--opp-text-mid);
        font-size: 12px;
        font-style: italic;
    }

    /* Action Buttons in Header */
    .action-buttons {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
    }

    .action-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1px;
        padding: 6px 10px;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s;
        color: #fff;
        font-weight: bold;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .action-btn i { font-size: 14px; }
    .action-btn span { font-size: 7px; }

    .attack-btn {
        background: linear-gradient(180deg, #8b2020 0%, #4a0a0a 100%);
        border: 2px solid #ff4444;
        box-shadow: 0 0 6px rgba(255, 68, 68, 0.3);
    }
    .attack-btn:hover {
        background: linear-gradient(180deg, #a53030 0%, #8b2020 100%);
        box-shadow: 0 0 12px rgba(255, 68, 68, 0.6);
        transform: translateY(-1px);
    }

    .reaction-btn {
        background: linear-gradient(180deg, #5a2082 0%, #2d0050 100%);
        border: 2px solid #bb88ff;
        box-shadow: 0 0 6px rgba(187, 136, 255, 0.3);
    }
    .reaction-btn:hover {
        background: linear-gradient(180deg, #6a30a2 0%, #5a2082 100%);
        box-shadow: 0 0 12px rgba(187, 136, 255, 0.6);
        transform: translateY(-1px);
    }

    .afflict-btn {
        background: linear-gradient(180deg, #2d6a27 0%, #0f3a0a 100%);
        border: 2px solid #66dd66;
        box-shadow: 0 0 6px rgba(102, 221, 102, 0.3);
    }
    .afflict-btn:hover {
        background: linear-gradient(180deg, #3d8a37 0%, #2d6a27 100%);
        box-shadow: 0 0 12px rgba(102, 221, 102, 0.6);
        transform: translateY(-1px);
    }

    /* ==================== EXECUTION TALISMAN VISUAL ==================== */
    .et-visual-row {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(20, 10, 30, 0.6);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 6px;
        padding: 6px 10px;
    }

    .et-mode-tabs {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
    }

    .et-mode-tab {
        padding: 4px 8px;
        font-size: 10px;
        font-weight: bold;
        background: rgba(var(--opp-bg-rgb), 0.6);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text-dim);
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .et-mode-tab:hover {
        background: rgba(var(--opp-dim-rgb), 0.4);
        color: var(--opp-text);
    }

    .et-mode-tab.active {
        background: linear-gradient(180deg, var(--opp-accent-dim) 0%, var(--opp-btn-top) 100%);
        border-color: var(--opp-accent);
        color: #fff;
    }

    .opponent-theme .et-max-input {
        width: 28px;
        padding: 1px 2px;
        text-align: center;
        font-size: 11px;
        font-weight: bold;
        background: rgba(0,0,0,0.3);
        border: 1px solid var(--opp-accent-faint2);
        border-radius: 3px;
        color: inherit;
    }

    .et-pips-container {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .et-label {
        font-size: 9px;
        font-weight: bold;
        color: var(--opp-accent);
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .et-pips {
        display: flex;
        gap: 3px;
        flex-wrap: wrap;
        flex: 1;
    }

    .et-pip {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: rgba(var(--opp-bg-rgb), 0.8);
        border: 2px solid var(--opp-accent-dim);
        cursor: pointer;
        transition: all 0.15s;
    }

    .et-pip:hover {
        border-color: var(--opp-accent);
        box-shadow: 0 0 6px var(--opp-accent-faint2);
    }

    .et-pip.filled {
        background: linear-gradient(135deg, #ff6666 0%, #cc0000 100%);
        border-color: #ff4444;
        box-shadow: 0 0 8px rgba(255, 68, 68, 0.6);
    }

    .et-pip.filled:hover {
        background: linear-gradient(135deg, #ff8888 0%, #ff4444 100%);
    }

    .et-counter {
        font-size: 12px;
        font-weight: bold;
        color: #ff8080;
        min-width: 40px;
        text-align: right;
    }

    /* ==================== TABS ==================== */
    .opponent-theme .sheet-tabs {
        display: flex;
        gap: 4px;
        background: rgba(26, 16, 40, 0.7);
        padding: 6px;
        border-radius: 6px;
        border: 1px solid var(--opp-accent-dim);
        flex: none !important;
        flex-grow: 0 !important;
        flex-shrink: 0 !important;
    }

    .opponent-theme .tab-item {
        flex: 1;
        font-family: 'Pirata One', serif;
        font-size: 16px;
        padding: 8px 12px;
        text-align: center;
        background: rgba(var(--opp-bg-rgb), 0.6);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text-dim);
        cursor: pointer;
        transition: all 0.2s;
    }

    .opponent-theme .tab-item:hover {
        background: rgba(var(--opp-dim-rgb), 0.4);
        color: var(--opp-text);
    }

    .opponent-theme .tab-item.active {
        background: linear-gradient(180deg, var(--opp-accent-dim) 0%, var(--opp-btn-top) 100%);
        color: #fff;
        border-color: var(--opp-accent);
    }

    /* ==================== BODY ==================== */
    .opponent-theme .sheet-body {
        flex: 1 1 auto !important;
        min-height: 0;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .opponent-theme .overview {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* ==================== CARDS ==================== */
    .opponent-theme .content-card {
        background-image: url("systems/bastionlands/assets/backgrounds/paper2.jpg");
        background-color: var(--opp-card-bg);
        background-blend-mode: multiply;
        background-size: cover;
        border: 2px solid var(--opp-accent-dim);
        border-radius: 8px;
        padding: 12px;
    }

    .opponent-theme .card-header {
        font-family: 'Pirata One', serif;
        font-size: 18px;
        color: var(--opp-text-mid);
        text-align: center;
        margin: 0 0 10px 0;
        padding-bottom: 6px;
        border-bottom: 1px solid var(--opp-accent-dim);
    }

    .opponent-theme .card-header i {
        margin-right: 6px;
        color: var(--opp-accent);
    }

    .two-column {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    /* ==================== REACTIONS ==================== */
    .reactions-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .reaction-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .reaction-field.full-width {
        grid-column: 1 / -1;
    }

    .reaction-field label {
        font-size: 11px;
        font-weight: bold;
        color: var(--opp-text-dim);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .reaction-field label i {
        color: var(--opp-accent);
        font-size: 12px;
    }

    .reaction-field.stress-field label i {
        color: #ff6b6b;
    }

    .opponent-theme .reaction-field input {
        padding: 8px 10px;
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text);
        font-size: 13px;
    }

    .opponent-theme .reaction-field input::placeholder {
        color: var(--opp-accent-hover);
    }

    /* ==================== AFFLICTIONS ==================== */
    .afflictions-card {
        border-color: #2d6a27 !important;
    }

    .afflictions-card .card-header {
        color: #88dd88;
        border-color: #2d6a27;
    }

    .drop-hint {
        text-align: center;
        font-size: 11px;
        color: rgba(136, 221, 136, 0.6);
        font-style: italic;
        margin-bottom: 8px;
    }

    .afflictions-list {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 40px;
    }

    .affliction-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        background: rgba(45, 106, 39, 0.3);
        border: 1px solid #2d6a27;
        border-radius: 6px;
    }

    .affliction-icon {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        object-fit: cover;
        cursor: pointer;
        transition: transform 0.15s;
    }

    .affliction-icon:hover {
        transform: scale(1.1);
    }

    .affliction-name {
        flex: 1;
        color: #88dd88;
        font-weight: bold;
        font-size: 13px;
        cursor: pointer;
        transition: color 0.15s;
    }

    .affliction-name:hover {
        color: #aaffaa;
        text-decoration: underline;
    }

    /* ==================== TEXTAREAS ==================== */
    .opponent-theme .content-card textarea {
        width: 100%;
        padding: 10px;
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 6px;
        color: var(--opp-text);
        font-size: 13px;
        resize: vertical;
        line-height: 1.5;
    }

    .opponent-theme .content-card textarea::placeholder {
        color: var(--opp-accent-hover);
    }

    /* ==================== LISTS ==================== */
    .list-container, .abilities-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 10px;
    }

    .opponent-theme .list-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        background: rgba(var(--opp-bg-rgb), 0.6);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 6px;
    }

    .opponent-theme .list-item input {
        flex: 1;
        padding: 6px 10px;
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text);
        font-size: 13px;
    }

    .opponent-theme .list-item .bullet {
        color: var(--opp-accent);
        font-size: 20px;
        font-weight: bold;
    }

    /* ==================== ABILITIES ==================== */
    .opponent-theme .ability-item {
        padding: 12px;
        background: rgba(var(--opp-bg-rgb), 0.6);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 8px;
    }

    .ability-top {
        display: flex;
        gap: 8px;
        margin-bottom: 8px;
    }

    .opponent-theme .ability-top input {
        flex: 1;
        padding: 8px 10px;
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text);
        font-size: 13px;
    }

    .opponent-theme .trigger-input {
        max-width: 120px;
        color: var(--opp-text-mid) !important;
        border-color: var(--opp-accent) !important;
        font-style: italic;
    }

    .opponent-theme .ability-item textarea {
        width: 100%;
        padding: 8px 10px;
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text);
        font-size: 12px;
        resize: vertical;
    }

    /* ==================== BUTTONS ==================== */
    .opponent-theme .add-btn {
        width: 100%;
        padding: 10px;
        font-family: 'Pirata One', serif;
        font-size: 14px;
        background: linear-gradient(180deg, var(--opp-btn-top) 0%, var(--opp-btn-bot) 100%);
        border: 1px solid var(--opp-accent);
        border-radius: 6px;
        color: var(--opp-text);
        cursor: pointer;
        transition: all 0.2s;
    }

    .opponent-theme .add-btn:hover {
        background: linear-gradient(180deg, var(--opp-btn-top-hover) 0%, var(--opp-btn-bot-hover) 100%);
        box-shadow: 0 0 8px var(--opp-accent-hover);
    }

    .opponent-theme .remove-btn {
        width: 24px;
        height: 24px;
        min-width: 24px;
        padding: 0;
        background: linear-gradient(180deg, #8b2020 0%, #5c1010 100%);
        border: 1px solid #ff6666;
        border-radius: 4px;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        transition: all 0.2s;
    }

    .opponent-theme .remove-btn:hover {
        background: linear-gradient(180deg, #a53030 0%, #8b2020 100%);
        box-shadow: 0 0 6px rgba(255, 102, 102, 0.5);
    }

    .opponent-theme .chat-btn {
        width: 24px;
        height: 24px;
        min-width: 24px;
        padding: 0;
        background: linear-gradient(180deg, #2d6a27 0%, #1a4a17 100%);
        border: 1px solid #66dd66;
        border-radius: 4px;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        transition: all 0.2s;
    }

    .opponent-theme .chat-btn:hover {
        background: linear-gradient(180deg, #3d8a37 0%, #2d6a27 100%);
        box-shadow: 0 0 6px rgba(102, 221, 102, 0.5);
    }

    /* Notes hint */
    .notes-hint {
        text-align: center;
        font-size: 11px;
        color: rgba(212, 196, 240, 0.5);
        font-style: italic;
        margin-bottom: 8px;
    }

    /* ==================== PRESSURE ==================== */
    .pressure-row {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .opponent-theme .checkbox-wrap input {
        width: 18px;
        height: 18px;
        accent-color: var(--opp-accent);
    }

    .checkbox-wrap span {
        font-size: 14px;
        font-weight: bold;
        color: var(--opp-text);
    }

    .opponent-theme .pressure-row > input[type="text"] {
        flex: 1;
        padding: 8px 10px;
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        color: var(--opp-text);
        font-size: 13px;
    }

    /* ==================== EDITOR ==================== */
    .opponent-theme .editor-wrap {
        background: rgba(var(--opp-bg-rgb), 0.9);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 6px;
        min-height: 120px;
        padding: 10px;
    }

    .opponent-theme .editor-wrap .editor-content {
        color: var(--opp-text);
    }

    /* ==================== SCROLLBAR ==================== */
    .opponent-theme .sheet-body::-webkit-scrollbar {
        width: 10px;
    }

    .opponent-theme .sheet-body::-webkit-scrollbar-track {
        background: rgba(26, 16, 40, 0.5);
        border-radius: 5px;
    }

    .opponent-theme .sheet-body::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, var(--opp-accent-dim) 0%, var(--opp-btn-top) 100%);
        border-radius: 5px;
        border: 2px solid var(--opp-bg);
    }

    .opponent-theme .sheet-body::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(180deg, #7a5ca3 0%, #5a4483 100%);
    }

    /* ==================== FORM OVERRIDES ==================== */
    form.opponent-theme .content-card {
        display: block;
    }

    /* ==================== TAGS ==================== */
    .tags-row {
        background: rgba(20, 10, 30, 0.4);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 4px;
        padding: 6px 10px;
    }

    .tags-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: center;
    }

    .tag-item {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        background: linear-gradient(180deg, var(--opp-btn-top) 0%, var(--opp-btn-bot) 100%);
        border: 1px solid var(--opp-accent);
        border-radius: 12px;
        font-size: 11px;
        font-weight: bold;
        color: var(--opp-text);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .tag-remove-btn {
        width: 14px;
        height: 14px;
        padding: 0;
        background: transparent;
        border: none;
        color: #ff8888;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 8px;
        opacity: 0.6;
        transition: opacity 0.15s;
    }

    .tag-remove-btn:hover {
        opacity: 1;
    }

    .opponent-theme .tag-input {
        padding: 3px 8px;
        background: rgba(var(--opp-bg-rgb), 0.6);
        border: 1px dashed var(--opp-accent-dim);
        border-radius: 12px;
        color: var(--opp-text-dim);
        font-size: 11px;
        width: 80px;
        transition: all 0.2s;
    }

    .opponent-theme .tag-input:focus {
        background: rgba(var(--opp-bg-rgb), 0.9);
        border-style: solid;
        border-color: var(--opp-accent);
        width: 120px;
    }

    .opponent-theme .tag-input::placeholder {
        color: rgba(var(--opp-bg-rgb), 0.5);
    }

    /* ==================== RANGE ==================== */
    .range-label {
        font-size: 11px;
        font-weight: bold;
        color: var(--opp-accent);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .opponent-theme .range-select {
        padding: 2px 8px;
        background: rgba(var(--opp-dim-rgb), 0.4);
        border: 1px solid var(--opp-accent-dim);
        border-radius: 3px;
        color: var(--opp-text-mid);
        font-size: 11px;
        font-weight: bold;
    }

    .opponent-theme .range-select option {
        background: var(--opp-bg);
        color: var(--opp-text);
    }

    /* ==================== STRESS FORMULA ==================== */
    .stress-card {
        border-color: #8b2020 !important;
    }

    .stress-card .card-header {
        color: #ff8888;
        border-color: #8b2020;
    }

    .stress-formula-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-bottom: 12px;
    }

    .stress-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .stress-field.full-width {
        grid-column: 1 / -1;
    }

    .stress-field label {
        font-size: 10px;
        font-weight: bold;
        color: #ffaaaa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .opponent-theme .stress-field input {
        padding: 8px 10px;
        background: rgba(139, 32, 32, 0.3);
        border: 1px solid #8b2020;
        border-radius: 4px;
