        --opp-accent-dim:      var(--opp-accent-dim);
        --opp-btn-top:         var(--opp-btn-top);
        --opp-btn-bot:         var(--opp-btn-bot);
        --opp-btn-top-hover:   var(--opp-btn-top-hover);
        --opp-btn-bot-hover:   var(--opp-btn-bot-hover);
        --opp-bg:              var(--opp-bg);
        --opp-bg-dark:         var(--opp-bg-dark);
        --opp-card-bg:         var(--opp-card-bg);
        --opp-bg-rgb:          45, 31, 61;
        --opp-dim-rgb:         106, 76, 147;
        --opp-accent-glow:     var(--opp-accent-glow);
        --opp-accent-hover:    var(--opp-accent-hover);
