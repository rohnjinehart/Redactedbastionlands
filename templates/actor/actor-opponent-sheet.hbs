<form class="{{cssClass}} opponent flexcol opponent-theme {{system.opponentType}}" autocomplete="off">
    {{!-- Header --}}
    <header class="opponent-header">
        {{!-- Top Row: Portrait, Name, Type --}}
        <div class="header-top">
            <div class="portrait-frame">
                <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
            </div>
            <div class="name-section">
                <input class="name-input" name="name" type="text" value="{{actor.name}}" placeholder="Opponent Name"/>
                <div class="type-line">
                    <select name="system.opponentType" class="type-select">
                        <option value="ogre" {{#if (eq system.opponentType "ogre")}}selected{{/if}}>Ogre</option>
                        <option value="idol" {{#if (eq system.opponentType "idol")}}selected{{/if}}>Idol</option>
                        <option value="hound" {{#if (eq system.opponentType "hound")}}selected{{/if}}>Hound</option>
                        <option value="centipede" {{#if (eq system.opponentType "centipede")}}selected{{/if}}>Centipede</option>
                        <option value="toad" {{#if (eq system.opponentType "toad")}}selected{{/if}}>Toad</option>
                        <option value="lord" {{#if (eq system.opponentType "lord")}}selected{{/if}}>Lord</option>
                        <option value="mother" {{#if (eq system.opponentType "mother")}}selected{{/if}}>Mother</option>
                        <option value="imago" {{#if (eq system.opponentType "imago")}}selected{{/if}}>Imago</option>
                        <option value="other" {{#if (eq system.opponentType "other")}}selected{{/if}}>Other</option>
                    </select>
                    <span class="type-divider">|</span>
                    <span class="range-label">Form:</span>
                    <select name="system.range" class="range-select">
                        <option value="severed" {{#if (eq system.range "severed")}}selected{{/if}}>I - Severed</option>
                        <option value="fused" {{#if (eq system.range "fused")}}selected{{/if}}>II - Fused</option>
                        <option value="bound" {{#if (eq system.range "bound")}}selected{{/if}}>III - Bound</option>
                    </select>
                </div>
            </div>
        </div>

    </header>

    {{!-- Vitals & Combat --}}
    <div class="content-card opp-vitals-card">
      <div class="opp-vitals-grid">

        {{!-- COL 1: Vitals & Saves --}}
        <div class="opp-vitals-col">
          <h3 class="card-header opp-col-header">Vitals &amp; Saves</h3>
          <p class="notes-hint">Roll d20 ≤ value to succeed.</p>

          <div class="opp-virtue-row">
            <button type="button" class="rb-save-btn opp-save-btn" data-virtue="body">Body</button>
            <div class="opp-virtue-inputs">
              <input type="number" name="system.body.value"   value="{{system.body.value}}"   min="0" data-dtype="Number"/>
              <span>/</span>
              <input type="number" name="system.body.max"     value="{{system.body.max}}"     data-dtype="Number"/>
            </div>
            <progress class="opp-virtue-progress" value="{{system.body.value}}" max="{{system.body.max}}"></progress>
          </div>

          <div class="opp-virtue-row">
            <button type="button" class="rb-save-btn opp-save-btn" data-virtue="spirit">Psyche</button>
            <div class="opp-virtue-inputs">
              <input type="number" name="system.spirit.value" value="{{system.spirit.value}}" min="0" data-dtype="Number"/>
              <span>/</span>
              <input type="number" name="system.spirit.max"   value="{{system.spirit.max}}"   data-dtype="Number"/>
            </div>
            <progress class="opp-virtue-progress" value="{{system.spirit.value}}" max="{{system.spirit.max}}"></progress>
          </div>

          <div class="opp-virtue-row">
            <button type="button" class="rb-save-btn opp-save-btn" data-virtue="virtue">Virtue</button>
            <div class="opp-virtue-inputs">
              <input type="number" name="system.virtue.value" value="{{system.virtue.value}}" min="0" data-dtype="Number"/>
              <span>/</span>
              <input type="number" name="system.virtue.max"   value="{{system.virtue.max}}"   data-dtype="Number"/>
            </div>
            <progress class="opp-virtue-progress" value="{{system.virtue.value}}" max="{{system.virtue.max}}"></progress>
          </div>

          <div class="opp-virtue-row">
            <button type="button" class="rb-save-btn opp-save-btn" data-virtue="grace">Grace</button>
            <div class="opp-virtue-inputs">
              <input type="number" name="system.grace.value"  value="{{system.grace.value}}"  min="0" data-dtype="Number"/>
              <span>/</span>
              <input type="number" name="system.grace.max"    value="{{system.grace.max}}"    data-dtype="Number"/>
            </div>
            <progress class="opp-virtue-progress" value="{{system.grace.value}}" max="{{system.grace.max}}"></progress>
          </div>

          <div class="opp-divider"></div>

          <div class="opp-virtue-row">
            <span class="opp-save-btn opp-resolve-label">Resolve</span>
            <div class="opp-virtue-inputs">
              <input type="number" name="system.resolve.value" value="{{system.resolve.value}}" min="0" data-dtype="Number"/>
              <span>/</span>
              <input type="number" name="system.resolve.max"   value="{{system.resolve.max}}"   data-dtype="Number"/>
            </div>
            <progress class="opp-virtue-progress opp-resolve-progress"
                      value="{{system.resolve.value}}"
                      max="{{#if (gt system.resolve.max 0)}}{{system.resolve.max}}{{else}}1{{/if}}"></progress>
          </div>

          <div class="opp-divider"></div>
          <div class="fatigue-row">
            <input type="checkbox" name="system.burnout" {{#if system.burnout}}checked{{/if}} id="opp-burnout-check"/>
            <label for="opp-burnout-check" class="opp-stat-label" style="margin:0;cursor:pointer;">Burnout</label>
            <button type="button"
                    class="burnout-recover-btn{{#unless system.burnout}} burnout-recover-disabled{{/unless}}"
                    data-tooltip="Sin Raise - roll 2d4 and recover from burnout"
                    {{#unless system.burnout}}disabled{{/unless}}>Sin Raise</button>
          </div>
        </div>

        {{!-- COL 2: Weapons & Armor --}}
        <div class="opp-weapons-col">
          <h3 class="card-header opp-col-header">Weapons &amp; Armor</h3>

          <div class="opp-weapons-list">
            {{#each system.weapons}}
            <div class="opp-weapon-row" draggable="true" data-index="{{@index}}">
              <input type="text"   name="system.weapons.{{@index}}.name"   value="{{this.name}}"   placeholder="Weapon name…" class="opp-weapon-name"/>
              <input type="text"   name="system.weapons.{{@index}}.damage" value="{{this.damage}}" placeholder="d6"           class="opp-weapon-dmg"/>
              <button type="button" class="remove-btn opp-weapon-remove-btn" data-index="{{@index}}" title="Remove"><i class="fas fa-times"></i></button>
            </div>
            {{/each}}
          </div>

          <button type="button" class="add-btn opp-weapon-add-btn" style="margin-top:6px;">
            <i class="fas fa-plus"></i> Add Weapon
          </button>

          <div class="opp-divider"></div>

          <div class="opp-armor-row">
            <span class="opp-stat-label">Resistance (Armor)</span>
            <input type="number" name="system.armor" value="{{system.armor}}" min="0" class="opp-armor-input" data-dtype="Number"/>
          </div>
        </div>

        {{!-- COL 3: Combat --}}
        <div class="opp-combat-col">
          <h3 class="card-header opp-col-header">Combat</h3>
          <div class="opp-combat-btns">
            <button type="button" class="rb-attack-btn opp-combat-btn">⚔ Attack</button>
            <button type="button" class="rb-use-domain-btn opp-combat-btn">✦ Use Domain</button>
            <button type="button" class="rb-take-damage-btn opp-combat-btn">🛡 Take Damage</button>
            <button type="button" class="rb-virtue-loss-btn opp-combat-btn">💀 Vital Loss</button>
          </div>
        </div>

      </div>
    </div>

    {{!-- Content --}}
    <section class="sheet-body">
        <div class="overview">
            <div class="content-card">
                <h3 class="card-header">Description</h3>
                <textarea name="system.description" rows="2" placeholder="A brief description of this opponent...">{{system.description}}</textarea>
            </div>

            <div class="content-card opp-trauma-card">
                <h3 class="card-header">Trauma Questions</h3>
                {{#each system.traumas}}
                <div class="opp-trauma-row">
                    <input type="checkbox" name="system.traumas.{{@index}}.answered" {{#if this.answered}}checked{{/if}} id="opp-trauma-{{@index}}"/>
                    <input type="text" name="system.traumas.{{@index}}.question" value="{{this.question}}" placeholder="Trauma question..." class="opp-trauma-input"/>
                </div>
                {{/each}}
            </div>

            <div class="content-card opponent-domain-drop">
                <h3 class="card-header">Domains</h3>
                <p class="drop-hint">Drag domain items here from the compendium</p>
                <div class="opp-domain-list">
                    {{#each currentOpponentDomains}}
                    <div class="opponent-domain-item" draggable="true" data-domain-id="{{this.id}}" data-index="{{@index}}">
                        <img src="{{this.img}}" class="domain-icon" alt="{{this.name}}" title="{{this.name}}"/>
                        <span class="domain-name">{{this.name}}</span>
                        <button type="button" class="remove-btn remove-opponent-domain-btn" data-id="{{this.id}}"><i class="fas fa-times"></i></button>
                    </div>
                    {{/each}}
                </div>
            </div>

            <div class="two-column opp-tend-palace-row">
                <div class="content-card">
                    <h3 class="card-header">Tendencies</h3>
                    <textarea name="system.tendencies" rows="3" placeholder="It tends to do this thing...">{{system.tendencies}}</textarea>
                </div>
                <div class="content-card opp-palace-card">
                    <h3 class="card-header">Palace</h3>
                    <textarea name="system.conditionalEffects" rows="3" placeholder="Where the sin resides...">{{system.conditionalEffects}}</textarea>
                </div>
            </div>

            <div class="two-column opp-host-appear-row">
                <div class="content-card opp-host-card">
                    <h3 class="card-header">Host</h3>
                    <textarea name="system.behavior" rows="3" placeholder="Who did the SIN evolve from...">{{system.behavior}}</textarea>
                </div>
                <div class="content-card">
                    <h3 class="card-header">Appearance</h3>
                    <textarea name="system.appearance" rows="3" placeholder="Physical description...">{{system.appearance}}</textarea>
                </div>
            </div>

            <div class="content-card">
                <h3 class="card-header">GM Notes</h3>
                <p class="notes-hint">Lore, plot hooks, secret weaknesses, or session-specific reminders...</p>
                <div class="editor-wrap">
                    {{editor enrichedBiography target="system.biography" engine="prosemirror" button=true editable=editable}}
                </div>
            </div>

            <div class="content-card source-card">
                <div class="source-row">
                    <i class="fas fa-book"></i>
                    <label>Source:</label>
                    <input type="text" name="system.source" value="{{system.source}}" placeholder="Core p.XX, Games for Freaks p.XX"/>
                </div>
            </div>
        </div>

    </section>
</form>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Pirata+One&display=swap');

    /* ==================== CSS VARIABLES (default: purple) ==================== */
